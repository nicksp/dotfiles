{
  "amp.terminal.theme": "squirrelsong-dark-dp",
  // Disable adding Amp-Thread trailer in git commits
  "amp.git.commit.ampThread.enabled": false,
  // Disable adding Amp as co-author in git commits
  "amp.git.commit.coauthor.enabled": false,
  // Disable notification sound
  "amp.notifications.enabled": false,
  // Disable loading skills from Claude Code directories
  "amp.skills.disableClaudeCodeSkills": true,
  // Turn off checking for updates
  "amp.updates.mode": "disabled",
  // Block all MCP servers
  "amp.mcpPermissions": [
    {
      "matches": {
        "command": "*"
      },
      "action": "reject"
    },
    {
      "matches": {
        "url": "*"
      },
      "action": "reject"
    }
  ],
  "amp.gauge": "cost"
}
