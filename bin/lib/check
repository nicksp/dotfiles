#!/bin/bash
#
# Validate shell syntax, ShellCheck supported scripts, and formatting.

set -euo pipefail

shell_scripts=(
  setup.sh
  setup/*.sh
)

bash_syntax_files=(
  tilde/.bash_profile
)

zsh_syntax_files=(
  tilde/.zshenv
  tilde/.zshrc
  zsh/*.zsh
)

while IFS= read -r script; do
  shell_scripts+=("$script")
done < <(
  # Match shell scripts by shebang
  find bin -maxdepth 1 -type f \
    -exec grep -El '^#!(/bin/(ba)?sh|/usr/bin/env (ba)?sh)$' {} + \
    | grep -v '^bin/license$'
)

bash -n "${shell_scripts[@]}" "${bash_syntax_files[@]}"
zsh -n "${zsh_syntax_files[@]}"
shellcheck --severity=error "${shell_scripts[@]}"
prettier --log-level warn --ignore-unknown --check "**/*.{js,cjs,ts,md,json,sh}" "bin/*"
