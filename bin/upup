#!/bin/bash
#
# Get macOS software updates, update Homebrew, npm, dotfiles, VS Code and some other software.
#
# - Run updates:
#
# `upup`
#
# ---
# Author: Nick Plekhanov, https://plekhanov.me
# License: MIT
# https://github.com/nicksp/dotfiles

set -euo pipefail

header() {
  echo "$(tput sgr 0 1)$(tput setaf 6)$1$(tput sgr0)"
}

warning() {
  tput setaf 1
  echo "/!\\ $1 /!\\"
  tput sgr0
}

# Ask for the administrator password upfront
warning "Activate sudo"
sudo echo "Sudo activated!"
echo

# Dotfiles
dotfiles
echo

# macOS
header "Updating macOS system…"
sudo softwareupdate -ia --verbose
echo

# App Store
# https://github.com/mas-cli/mas#known-issues
# header "Updating apps from App Store…"
# mas upgrade
# echo

# Homebrew (formulae + casks without and with auto_updates)
header "Updating Homebrew packages…"
outdated_packages=$(brew outdated --greedy)
if [ -n "$outdated_packages" ]; then
  echo "📦 Outdated packages:"
  echo "$outdated_packages"
  brew upgrade --greedy
else
  echo "✨ All packages already up-to-date."
fi
echo

# Cleanup
header "Cleaning up Homebrew…"
brew cleanup --prune=all
brew doctor || true
echo

# Raycast
header "Updating Raycast and its extensions…"
open raycast://extensions/raycast/raycast/check-for-updates
open raycast://extensions/raycast/raycast/check-for-extension-updates
echo

# (p)npm
header "Updating global (p)npm modules…"
npx taze -g major -i
echo

# Coding agents
header "Updating coding agent tools…"
amp update
echo

# Nyan dog!
nyan
