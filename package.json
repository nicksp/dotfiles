{
  "name": "dotfiles",
  "version": "0.0.1",
  "packageManager": "pnpm@11.1.3",
  "type": "module",
  "description": "My personal dotfiles for configuring macOS with Zsh and Homebrew.",
  "private": "true",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "format": "prettier --log-level warn --ignore-unknown --write \"**/*.{js,cjs,ts,md,json,sh}\" \"bin/*\""
  },
  "author": "Nick Plekhanov",
  "license": "MIT",
  "dependencies": {
    "avif": "^0.5.3"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "prettier-plugin-sh": "^0.18.1"
  }
}
